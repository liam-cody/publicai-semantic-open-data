# Browser-exposed (Vite). Same key as in Nebius console.
# Node scripts (`embed-sample`, `smoke-nebius`, `smoke-app`) also read this file via scripts/load-dotenv.mjs.
VITE_NEBIUS_API_KEY=

# Optional — default https://api.tokenfactory.nebius.com/v1
# (Vite dev proxy uses this to choose the Nebius host; the browser still calls /api/nebius to avoid CORS.)
# VITE_NEBIUS_BASE_URL=https://api.studio.nebius.ai/v1

# Set to 0 only if you need the browser to call VITE_NEBIUS_BASE_URL directly (rare; needs CORS on that API).
# VITE_NEBIUS_BROWSER_PROXY=0

# Optional model overrides (defaults work with Nebius Token Factory catalog)
# VITE_NEBIUS_CHAT_MODEL=meta-llama/Llama-3.3-70B-Instruct
# VITE_NEBIUS_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

# For npm run embed-sample / smoke-nebius (Node reads these without VITE_ prefix)
# NEBIUS_API_KEY=
# NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1
# NEBIUS_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
# NEBIUS_CHAT_MODEL=meta-llama/Llama-3.3-70B-Instruct
